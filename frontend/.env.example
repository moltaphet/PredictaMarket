# Predicta dashboard configuration.
# Copy to `.env.local` and fill in your deployed contract address.

# Address of the deployed PredictaMarket intelligent contract.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# GenLayer network RPC endpoint. StudioNet is gasless and needs no funded account.
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com/api

# Native token symbol shown in the UI.
NEXT_PUBLIC_GENLAYER_SYMBOL=GEN
